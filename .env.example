# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Same PostgreSQL instance as DocHub
DATABASE_URL="postgresql://user:password@db:5432/dochub"

# ─── NEXTAUTH ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://tickethub.yourdomain.com"
# IMPORTANT: Use the SAME secret as DocHub to enable shared sessions
NEXTAUTH_SECRET="your-shared-secret-here"

# ─── MICROSOFT ENTRA ID ───────────────────────────────────────────────────────
# Can reuse DocHub's Entra ID app registration
# Add https://tickethub.yourdomain.com/api/auth/callback/azure-ad as redirect URI
AZURE_AD_CLIENT_ID="your-entra-client-id"
AZURE_AD_CLIENT_SECRET="your-entra-client-secret"
AZURE_AD_TENANT_ID="your-entra-tenant-id"

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── NOTIFICATIONS ────────────────────────────────────────────────────────────
# Self-hosted ntfy server URL (Docker container on same host)
NTFY_URL="https://ntfy.yourdomain.com"
NTFY_AUTH_TOKEN=""  # optional — if ntfy requires auth

# Pushover for critical/P1 alerts
PUSHOVER_APP_TOKEN="your-pushover-app-token"

# ─── ACCOUNTING INTEGRATIONS ──────────────────────────────────────────────────
# QuickBooks OAuth2
QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""
QUICKBOOKS_ENVIRONMENT="production"  # or "sandbox"

# Xero OAuth2 (alternative to QuickBooks)
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""

# ─── CRON PROTECTION ──────────────────────────────────────────────────────────
# Bearer token for protected cron endpoints
# Generate: openssl rand -base64 32
CRON_SECRET="your-cron-secret-here"

# ─── POSTGRES (for docker-compose db service) ────────────────────────────────
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="your-postgres-password"
POSTGRES_DB="dochub"

# ─── DEVELOPMENT ONLY ─────────────────────────────────────────────────────────
# Uncomment for local dev
# NEXTAUTH_URL="http://localhost:3001"
