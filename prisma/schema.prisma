// ─── AUTOMATION ENGINE ───────────────────────────────────────────────────
// Phase 0: event plumbing. Rules/runs/deferred tables exist; only a
// synthetic catch-all rule logs every emitted event for verification.
// Full rule evaluator ships in Phase 1 — see AUTOMATION plan doc.

/// User-defined "IF <event> THEN <actions>" rule. EVENT / SCHEDULED /
/// TIME_IN_STATE triggers; JSON condition tree; ordered action list.
model TH_AutomationRule {
  id            String   @id @default(cuid())
  name          String
  description   String?
  enabled       Boolean  @default(true)
  /// When true, conditions evaluate and matches log to TH_AutomationRun,
  /// but actions do NOT execute. Recovery lever for risky rules.
  dryRun        Boolean  @default(false)
  /// Lower number runs first within the same trigger. Defaults to 100.
  priority      Int      @default(100)
  /// "EVENT" | "SCHEDULED" | "TIME_IN_STATE"
  triggerType   String
  /// Trigger-specific config. See plan doc for shape per triggerType.
  triggerConfig Json
  /// Boolean tree of { field, op, value } leaves with all/any/not combinators.
  /// Empty object {} means always-true.
  conditions    Json
  /// Ordered array of action objects: [{ type, params, stopChainOnFailure? }, ...]
  actions       Json
  /// Free-text labels for UI grouping.
  tags          String[] @default([])

  /// "DRAFT" | "PENDING_APPROVAL" | "APPROVED" | "REJECTED"
  /// Non-admins can create rules but they require admin approval before
  /// firing. Seeded system rules default to APPROVED. Edits to an
  /// APPROVED rule by a non-admin flip it back to PENDING_APPROVAL.
  approvalStatus String    @default("APPROVED")
  submittedAt    DateTime?
  approvedAt     DateTime?
  approvedById   String?
  rejectedAt     DateTime?
  rejectedById   String?
  rejectionNote  String?

  createdById String
  createdBy   TH_User  @relation("AutomationRuleCreator", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   TH_User? @relation("AutomationRuleUpdater", fields: [updatedById], references: [id])
  approvedBy  TH_User? @relation("AutomationRuleApprover", fields: [approvedById], references: [id])
  rejectedBy  TH_User? @relation("AutomationRuleRejecter", fields: [rejectedById], references: [id])

  lastFiredAt  DateTime?
  fireCount    Int       @default(0)
  failureCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs            TH_AutomationRun[]
  deferredActions TH_AutomationDeferredAction[]

  @@index([enabled, triggerType])
  @@index([approvalStatus])
  @@map("th_automation_rules")
  @@schema("tickethub")
}

/// Audit row for every rule evaluation — matched OR skipped OR errored.
/// Entity is referenced by (entityType, entityId) string pair; no FK so
/// deleting entities doesn't cascade-corrupt audit history.
model TH_AutomationRun {
  id     String            @id @default(cuid())
  ruleId String
  rule   TH_AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  entityType   String
  entityId     String
  eventType    String
  eventPayload Json
  eventAt      DateTime

  /// "MATCHED" | "SKIPPED_CONDITIONS" | "SKIPPED_DISABLED" | "SKIPPED_DRYRUN" | "ERROR"
  result          String
  /// Per-condition pass/fail trace; null until Phase 1 evaluator ships.
  conditionsTrace Json?
  /// [{ type, params, result: "OK"|"FAIL", error? }]
  actionsRun      Json?
  errorMessage    String?

  /// Groups runs triggered by the same root event across a chain of actions.
  chainId     String
  chainDepth  Int     @default(0)
  parentRunId String?

  createdAt DateTime @default(now())

  @@index([ruleId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([chainId])
  @@map("th_automation_runs")
  @@schema("tickethub")
}

/// Action scheduled by `chain.defer` for execution at `fireAt`. Drained
/// every minute by api/cron/automation-deferred. `recheckConditions`
/// re-verifies the rule's conditions against current state at fire time.
model TH_AutomationDeferredAction {
  id                String            @id @default(cuid())
  ruleId            String
  rule              TH_AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  parentRunId       String
  entityType        String
  entityId          String
  action            Json
  recheckConditions Boolean           @default(true)
  fireAt            DateTime
  /// "PENDING" | "FIRED" | "SKIPPED" | "FAILED" | "CANCELLED"
  status            String            @default("PENDING")
  firedAt           DateTime?
  errorMessage      String?
  chainId           String
  chainDepth        Int

  createdAt DateTime @default(now())

  @@index([status, fireAt])
  @@map("th_automation_deferred")
  @@schema("tickethub")
}
