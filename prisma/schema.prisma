model TH_RecurringTicketTemplate {
  id   String @id @default(cuid())
  name String

  // What ticket to create
  clientId     String
  client       TH_Client    @relation(fields: [clientId], references: [id])
  siteId       String?
  site         TH_Site?     @relation(fields: [siteId], references: [id])
  contactId    String?
  contact      TH_Contact?  @relation(fields: [contactId], references: [id])
  contractId   String?
  contract     TH_Contract? @relation(fields: [contractId], references: [id])
  assignedToId String?
  assignedTo   TH_User?     @relation("RecurringTemplateAssignee", fields: [assignedToId], references: [id])

  title       String
  description String?
  priority    TH_TicketPriority @default(MEDIUM)
  type        TH_TicketType     @default(SERVICE_REQUEST)

  // Schedule
  frequency    TH_RecurringFrequency
  /// Every N units (days/weeks/months). 1 = every period.
  interval     Int                   @default(1)
  /// 0=Sunday..6=Saturday (WEEKLY only).
  dayOfWeek    Int?
  /// 1..31 (MONTHLY only). If > days in month, clamped to last day.
  dayOfMonth   Int?
  /// 0..23 — fire hour in template timezone.
  hourOfDay    Int                   @default(8)
  /// 0..59 — fire minute in template timezone.
  minuteOfHour Int                   @default(0)
  /// IANA timezone the schedule is interpreted in.
  timezone     String                @default("America/New_York")

  active    Boolean   @default(true)
  nextRunAt DateTime
  lastRunAt DateTime?
  runCount  Int       @default(0)

  createdById String
  createdBy   TH_User @relation("RecurringTemplateCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets TH_Ticket[]

  @@index([active, nextRunAt])
  @@map("th_recurring_ticket_templates")
  @@schema("tickethub")
}

