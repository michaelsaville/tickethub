// ─── SAVED PAYMENT METHODS ───────────────────────────────────────────────
// Card references stored on a Stripe Customer attached to TH_Client. Card
// details (number, CVC) never touch our server — Stripe Elements tokenizes
// client-side and returns a PaymentMethod ID we attach to the Customer.

model TH_SavedPaymentMethod {
  id                    String    @id @default(cuid())
  clientId              String
  client                TH_Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  /// Stripe PaymentMethod ID (`pm_…`). Source of truth lives on Stripe;
  /// our row is a cache for list rendering + charge dispatch.
  stripePaymentMethodId String    @unique
  /// Card brand — visa, mastercard, amex, discover, etc.
  brand                 String
  last4                 String
  expMonth              Int
  expYear               Int
  /// Cardholder name as provided during the SetupIntent, if any.
  cardholderName        String?
  isDefault             Boolean   @default(false)
  /// Last time this card was used to successfully charge an invoice.
  lastUsedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([clientId])
  @@map("th_saved_payment_methods")
  @@schema("tickethub")
}

