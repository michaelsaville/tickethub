// TicketHub Prisma Schema
// Shared PostgreSQL database with DocHub. All models prefixed TH_ and mapped
// to th_* tables so no namespace conflicts with DocHub models.
// Schema is additive only after first migration — never rename or drop columns.
// All monetary values stored as integers (cents).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Isolate TicketHub in its own Postgres schema so db push never touches
  // DocHub's public schema. Both apps share the same database/role, but
  // Prisma's drift detection only manages tables in schemas it knows about.
  schemas  = ["tickethub"]
}

// ─── CLIENTS ──────────────────────────────────────────────────────────────

model TH_Client {
  id            String   @id @default(cuid())
  name          String
  shortCode     String?  @unique
  internalNotes String?
  /// ISO 3166-2 US state code (WV/MD/PA/…) — determines sales tax rate
  /// at invoice time. Frozen onto TH_Invoice.taxState at invoice creation
  /// so historical invoices survive rate changes.
  billingState  String?
  /// Direct billing email for invoices — overrides the primary contact
  /// email when set. Useful when a client has an ap@ / billing@ mailbox
  /// separate from the person you talk to day to day.
  billingEmail  String?
  /// Per-client opt-out for automated ticket emails (new ticket opened,
  /// public reply added). Master kill switch is `TICKETHUB_CLIENT_EMAILS_ENABLED`
  /// env var — this flag only matters when the env is ON.
  emailClientOnTicketEvents Boolean @default(true)
  syncroId      Int?     @unique // Syncro customer ID for migration dedup
  qboCustomerId String?           // cached QBO customer ID for invoice sync
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contacts  TH_Contact[]
  sites     TH_Site[]
  contracts TH_Contract[]
  tickets   TH_Ticket[]
  assets    TH_Asset[]
  invoices  TH_Invoice[]
  estimates TH_Estimate[]

  @@map("th_clients")
  @@schema("tickethub")
}

model TH_Contact {
  id        String   @id @default(cuid())
  clientId  String
  client    TH_Client @relation(fields: [clientId], references: [id])
  firstName String
  lastName  String
  email     String?
  phone     String?
  jobTitle  String?
  isPrimary      Boolean  @default(false)
  syncroContactId Int?    @unique // Syncro contact ID for migration dedup
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tickets       TH_Ticket[]
  reminders     TH_Reminder[]
  portalTokens  TH_ContactPortalToken[]
  estimates     TH_Estimate[]

  @@map("th_contacts")
  @@schema("tickethub")
}

model TH_Site {
  id        String   @id @default(cuid())
  clientId  String
  client    TH_Client @relation(fields: [clientId], references: [id])
  name      String
  address   String?
  city      String?
  state     String?
  zip       String?
  country   String   @default("US")
  latitude  Float?
  longitude Float?
  syncroSiteId Int? @unique // Syncro service address ID for migration dedup
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets        TH_Ticket[]
  stoppingPoints TH_StoppingPoint[]

  @@map("th_sites")
  @@schema("tickethub")
}

// ─── CONTRACTS ────────────────────────────────────────────────────────────

enum TH_ContractType {
  GLOBAL
  BLOCK_HOURS
  RECURRING
  TIME_AND_MATERIAL
  PROJECT
  @@schema("tickethub")
}

enum TH_ContractStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
  @@schema("tickethub")
}

model TH_Contract {
  id             String            @id @default(cuid())
  clientId       String
  client         TH_Client         @relation(fields: [clientId], references: [id])
  name           String
  type           TH_ContractType   @default(GLOBAL)
  status         TH_ContractStatus @default(ACTIVE)
  startDate      DateTime?
  endDate        DateTime?
  monthlyFee     Int?
  blockHours     Float?
  blockHoursUsed Float             @default(0)
  notes          String?
  isGlobal       Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  priceExceptions TH_ContractPriceException[]
  charges         TH_Charge[]
  tickets         TH_Ticket[]
  estimates       TH_Estimate[]

  @@map("th_contracts")
  @@schema("tickethub")
}

model TH_ContractPriceException {
  id            String      @id @default(cuid())
  contractId    String
  contract      TH_Contract @relation(fields: [contractId], references: [id])
  itemId        String
  item          TH_Item     @relation(fields: [itemId], references: [id])
  priceOverride Int
  createdAt     DateTime    @default(now())

  @@map("th_contract_price_exceptions")
  @@schema("tickethub")
}

// ─── ITEMS (CATALOG) ──────────────────────────────────────────────────────

enum TH_ItemType {
  LABOR
  PART
  EXPENSE
  LICENSE
  CONTRACT_FEE
  @@schema("tickethub")
}

model TH_Item {
  id           String      @id @default(cuid())
  name         String
  code         String?     @unique
  type         TH_ItemType
  defaultPrice Int
  costPrice    Int?
  taxable      Boolean     @default(true)
  accountCode  String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  charges         TH_Charge[]
  priceExceptions TH_ContractPriceException[]
  estimateItems   TH_EstimateItem[]

  @@map("th_items")
  @@schema("tickethub")
}

// ─── CHARGES (THE BILLING BACKBONE) ───────────────────────────────────────

enum TH_ChargeStatus {
  NOT_BILLABLE
  BILLABLE
  INVOICED
  LOCKED
  @@schema("tickethub")
}

enum TH_ChargeType {
  LABOR
  PART
  EXPENSE
  CONTRACT_FEE
  @@schema("tickethub")
}

model TH_Charge {
  id           String          @id @default(cuid())
  ticketId     String?
  ticket       TH_Ticket?      @relation(fields: [ticketId], references: [id])
  contractId   String
  contract     TH_Contract     @relation(fields: [contractId], references: [id])
  itemId       String
  item         TH_Item         @relation(fields: [itemId], references: [id])
  technicianId String?
  technician   TH_User?        @relation(fields: [technicianId], references: [id])
  invoiceId    String?
  invoice      TH_Invoice?     @relation(fields: [invoiceId], references: [id])

  type        TH_ChargeType
  status      TH_ChargeStatus @default(BILLABLE)
  description String?

  timeSpentMinutes   Int?
  timeChargedMinutes Int?

  quantity   Float @default(1)
  unitPrice  Int
  totalPrice Int

  workDate   DateTime @default(now())
  isBillable Boolean  @default(true)

  externalRef String?
  clientOpId  String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fuelReceipt TH_FuelReceipt?
  ticketPart  TH_TicketPart?
  appointment TH_Appointment?

  @@map("th_charges")
  @@schema("tickethub")
}

// ─── TICKETS ──────────────────────────────────────────────────────────────

enum TH_TicketStatus {
  NEW
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  WAITING_THIRD_PARTY
  RESOLVED
  CLOSED
  CANCELLED
  @@schema("tickethub")
}

enum TH_TicketPriority {
  URGENT
  HIGH
  MEDIUM
  LOW
  @@schema("tickethub")
}

enum TH_TicketType {
  INCIDENT
  SERVICE_REQUEST
  PROBLEM
  CHANGE
  MAINTENANCE
  INTERNAL
  @@schema("tickethub")
}

model TH_Ticket {
  id           String       @id @default(cuid())
  ticketNumber Int          @unique @default(autoincrement())
  clientId     String
  client       TH_Client    @relation(fields: [clientId], references: [id])
  contactId    String?
  contact      TH_Contact?  @relation(fields: [contactId], references: [id])
  siteId       String?
  site         TH_Site?     @relation(fields: [siteId], references: [id])
  contractId   String?
  contract     TH_Contract? @relation(fields: [contractId], references: [id])
  assetId      String?
  asset        TH_Asset?    @relation(fields: [assetId], references: [id])
  // Cross-app link to DocHub asset (public schema). Not a FK — just stores
  // the DocHub Asset.id so the UI can render a link to dochub.pcc2k.com/assets/:id
  dochubAssetId   String?
  dochubAssetName String?   // cached display name to avoid cross-schema query on every load
  assignedToId String?
  assignedTo   TH_User?     @relation("AssignedTickets", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    TH_User      @relation("CreatedTickets", fields: [createdById], references: [id])

  title       String
  description String?
  status      TH_TicketStatus   @default(NEW)
  priority    TH_TicketPriority @default(MEDIUM)
  type        TH_TicketType     @default(INCIDENT)
  board       String?

  slaResponseDue      DateTime?
  slaResolveDue       DateTime?
  slaBreached         Boolean   @default(false)
  slaPausedAt         DateTime?
  /// Highest SLA elapsed threshold already notified on, in percent
  /// (0 = none, 50 = gentle, 75 = urgent, 90 = critical, 100 = breached).
  /// Ensures the escalation cron only fires once per threshold per ticket.
  slaLastNotifiedBps  Int       @default(0)

  isUnread        Boolean   @default(false)
  lastClientReply DateTime?

  estimatedMinutes Int?

  checklist Json?

  syncroId  Int?      @unique // Syncro ticket ID for migration dedup

  closedAt  DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  comments     TH_TicketComment[]
  charges      TH_Charge[]
  attachments  TH_Attachment[]
  timeline     TH_TicketEvent[]
  parts        TH_TicketPart[]
  signatures   TH_Signature[]
  tags         TH_TicketTag[]
  appointments TH_Appointment[]

  @@map("th_tickets")
  @@schema("tickethub")
}

model TH_TicketComment {
  id         String    @id @default(cuid())
  ticketId   String
  ticket     TH_Ticket @relation(fields: [ticketId], references: [id])
  authorId   String
  author     TH_User   @relation(fields: [authorId], references: [id])
  body       String
  isInternal Boolean   @default(false)
  clientOpId String?   @unique
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("th_ticket_comments")
  @@schema("tickethub")
}

model TH_TicketEvent {
  id        String    @id @default(cuid())
  ticketId  String
  ticket    TH_Ticket @relation(fields: [ticketId], references: [id])
  userId    String?
  user      TH_User?  @relation(fields: [userId], references: [id])
  type      String
  data      Json?
  createdAt DateTime  @default(now())

  @@map("th_ticket_events")
  @@schema("tickethub")
}

model TH_TicketTag {
  id       String    @id @default(cuid())
  ticketId String
  ticket   TH_Ticket @relation(fields: [ticketId], references: [id])
  tag      String

  @@unique([ticketId, tag])
  @@map("th_ticket_tags")
  @@schema("tickethub")
}

// ─── PARTS (PROCUREMENT) ──────────────────────────────────────────────────

enum TH_PartStatus {
  PENDING_ORDER
  ORDERED
  RECEIVED
  INSTALLED
  RETURNED
  @@schema("tickethub")
}

model TH_TicketPart {
  id        String    @id @default(cuid())
  ticketId  String
  ticket    TH_Ticket @relation(fields: [ticketId], references: [id])
  addedById String
  addedBy   TH_User   @relation(fields: [addedById], references: [id])

  name        String
  asin        String?
  vendor      String? @default("Amazon Business")
  vendorUrl   String?
  imageUrl    String?
  orderNumber String?

  quantity  Int           @default(1)
  unitCost  Int
  unitPrice Int
  status    TH_PartStatus @default(PENDING_ORDER)

  chargeId String?    @unique
  charge   TH_Charge? @relation(fields: [chargeId], references: [id])

  accountCode String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("th_ticket_parts")
  @@schema("tickethub")
}

// ─── ASSETS ───────────────────────────────────────────────────────────────

model TH_Asset {
  id        String    @id @default(cuid())
  clientId  String
  client    TH_Client @relation(fields: [clientId], references: [id])
  name      String
  type      String?
  make      String?
  model     String?
  serial    String?
  ipAddress String?
  notes     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tickets TH_Ticket[]

  @@map("th_assets")
  @@schema("tickethub")
}

// ─── INVOICES ─────────────────────────────────────────────────────────────

enum TH_InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  VOID
  @@schema("tickethub")
}

model TH_Invoice {
  id            String    @id @default(cuid())
  invoiceNumber Int       @unique @default(autoincrement())
  clientId      String
  client        TH_Client @relation(fields: [clientId], references: [id])
  contractId    String?

  status    TH_InvoiceStatus @default(DRAFT)
  issueDate DateTime         @default(now())
  dueDate   DateTime?

  subtotal        Int
  taxableSubtotal Int     @default(0) // cents — portion of subtotal that was taxed
  taxState        String?              // frozen from client.billingState
  taxRate         Int     @default(0)  // basis points (600 = 6.00%)
  taxAmount       Int     @default(0)
  totalAmount     Int

  notes String?

  externalRef   String?
  sentAt        DateTime?
  paidAt        DateTime?
  firstViewedAt DateTime?
  viewCount     Int       @default(0)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  charges     TH_Charge[]
  attachments TH_Attachment[]

  @@map("th_invoices")
  @@schema("tickethub")
}

// ─── ESTIMATES / QUOTES ───────────────────────────────────────────────────

enum TH_EstimateStatus {
  DRAFT
  SENT
  APPROVED
  DECLINED
  EXPIRED
  CONVERTED
  @@schema("tickethub")
}

model TH_Estimate {
  id              String             @id @default(cuid())
  estimateNumber  Int                @unique @default(autoincrement())
  clientId        String
  client          TH_Client          @relation(fields: [clientId], references: [id])
  contactId       String?
  contact         TH_Contact?        @relation(fields: [contactId], references: [id])
  contractId      String?
  contract        TH_Contract?       @relation(fields: [contractId], references: [id])

  status      TH_EstimateStatus @default(DRAFT)
  title       String
  description String?

  subtotal        Int     @default(0)
  taxableSubtotal Int     @default(0)
  taxState        String?
  taxRate         Int     @default(0)
  taxAmount       Int     @default(0)
  totalAmount     Int     @default(0)

  validUntil  DateTime?
  notes       String?

  externalRef String? // Syncro estimate ID for imported estimates

  convertedToInvoiceId String?

  sentAt      DateTime?
  approvedAt  DateTime?
  declinedAt  DateTime?
  convertedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items TH_EstimateItem[]

  @@map("th_estimates")
  @@schema("tickethub")
}

model TH_EstimateItem {
  id          String      @id @default(cuid())
  estimateId  String
  estimate    TH_Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  itemId      String
  item        TH_Item     @relation(fields: [itemId], references: [id])

  description String?
  quantity    Float       @default(1)
  unitPrice   Int         // cents
  totalPrice  Int         // cents (quantity × unitPrice)

  sortOrder   Int         @default(0)

  createdAt DateTime @default(now())

  @@map("th_estimate_items")
  @@schema("tickethub")
}

// ─── FUEL RECEIPTS ────────────────────────────────────────────────────────

model TH_FuelReceipt {
  id            String  @id @default(cuid())
  submittedById String
  submittedBy   TH_User @relation(fields: [submittedById], references: [id])

  date           DateTime?
  vendor         String?
  address        String?
  fuelType       String?
  gallons        Float?
  pricePerGallon Float?
  totalAmount    Int?
  paymentMethod  String?
  vehicle        String?
  notes          String?

  imageUrl String?

  chargeId String?    @unique
  charge   TH_Charge? @relation(fields: [chargeId], references: [id])

  accountCode String? @default("Fuel & Vehicle Expense")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("th_fuel_receipts")
  @@schema("tickethub")
}

// ─── SCHEDULING ───────────────────────────────────────────────────────────

enum TH_AppointmentStatus {
  SCHEDULED
  EN_ROUTE
  ON_SITE
  COMPLETE
  CANCELLED

  @@schema("tickethub")
}

model TH_Appointment {
  id             String    @id @default(cuid())
  ticketId       String
  ticket         TH_Ticket @relation(fields: [ticketId], references: [id])
  technicianId   String
  technician     TH_User   @relation("TechAppointments", fields: [technicianId], references: [id])
  createdById    String
  createdBy      TH_User   @relation("CreatedAppointments", fields: [createdById], references: [id])

  scheduledStart DateTime
  scheduledEnd   DateTime
  actualStart    DateTime?
  actualEnd      DateTime?
  travelMinutes  Int?

  notes  String?
  status TH_AppointmentStatus @default(SCHEDULED)

  // Link to charge created on completion
  chargeId String?     @unique
  charge   TH_Charge?  @relation(fields: [chargeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([technicianId, scheduledStart])
  @@index([ticketId])
  @@map("th_appointments")
  @@schema("tickethub")
}

model TH_WorkingHours {
  id           String  @id @default(cuid())
  userId       String
  user         TH_User @relation(fields: [userId], references: [id])
  dayOfWeek    Int     // 0=Sun, 1=Mon, ..., 6=Sat
  startTime    String  // "08:00" (HH:mm)
  endTime      String  // "17:00" (HH:mm)
  isWorkingDay Boolean @default(true)

  @@unique([userId, dayOfWeek])
  @@map("th_working_hours")
  @@schema("tickethub")
}

// ─── USERS ────────────────────────────────────────────────────────────────

model TH_User {
  id         String  @id @default(cuid())
  entraId    String  @unique
  email      String  @unique
  name       String
  role       String  @default("TECH")
  hourlyRate Int?
  isActive   Boolean @default(true)

  togglToken    String?
  todoistToken  String?
  pushoverToken String?
  ntfyTopic     String?
  /// ON_CALL (all notifications), WORKING (assigned + SLA only, default),
  /// OFF_DUTY (critical only — Pushover)
  notificationMode String @default("WORKING")

  /// Email addresses this tech owns — mail from any of these lands in
  /// the Inbox dashboard as a forwarder candidate (never auto-creates).
  inboundForwardEmails String[] @default([])

  /// Whether to show the cross-app shortcut to the DocHub personal
  /// password vault in the TicketHub sidebar. Per-user opt-out.
  showVaultLink Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedTickets TH_Ticket[]        @relation("AssignedTickets")
  createdTickets  TH_Ticket[]        @relation("CreatedTickets")
  charges         TH_Charge[]
  comments        TH_TicketComment[]
  appointments        TH_Appointment[]   @relation("TechAppointments")
  createdAppointments TH_Appointment[]   @relation("CreatedAppointments")
  workingHours        TH_WorkingHours[]
  fuelReceipts    TH_FuelReceipt[]
  ticketEvents    TH_TicketEvent[]
  parts           TH_TicketPart[]
  forwardedInboundEmails TH_PendingInboundEmail[] @relation("ForwardedInboundEmails")
  locationPings    TH_LocationPing[]   @relation("LocationPings")
  stoppingPoints   TH_StoppingPoint[]  @relation("StoppingPoints")
  remindersCreated TH_Reminder[]       @relation("ReminderCreator")

  @@map("th_users")
  @@schema("tickethub")
}

// ─── INBOUND EMAIL INBOX ──────────────────────────────────────────────────

enum TH_PendingInboundEmailStatus {
  PENDING
  APPROVED
  DISMISSED

  @@schema("tickethub")
}

/// Inbound emails that didn't get auto-matched into an existing ticket
/// or auto-created via a known contact. Shows up on /inbox for manual
/// triage. Populated by the M365 Graph webhook.
model TH_PendingInboundEmail {
  id               String                       @id @default(cuid())
  graphMessageId   String                       @unique
  fromEmail        String
  fromName         String?
  subject          String
  bodyText         String
  bodyHtml         String?
  snippet          String
  receivedAt       DateTime
  /// Which monitored mailbox received this email (e.g. accounting@pcc2k.com).
  mailbox          String?
  status           TH_PendingInboundEmailStatus @default(PENDING)
  /// If this email is a "forwarded by a tech" candidate, the user
  /// who forwarded it. The dashboard shows a badge and the
  /// create-ticket modal pre-fills assignee to this user.
  forwardedByUserId String?
  forwardedBy      TH_User?                     @relation("ForwardedInboundEmails", fields: [forwardedByUserId], references: [id])
  /// Rolling "plus N more" counter — additional emails from the same
  /// sender within the rate-limit window append into this row instead
  /// of creating new ones.
  additionalCount  Int                          @default(0)
  /// After approval, the ticket that was created (audit trail).
  matchedTicketId  String?
  handledById      String?
  handledAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, receivedAt])
  @@index([fromEmail])
  @@map("th_pending_inbound_emails")
  @@schema("tickethub")
}

/// Audit trail for outbound ticket-related emails sent to clients
/// (new ticket opened, public reply added). Used for:
///   1. Debugging ("did we email them?" without grepping logs)
///   2. Rate limiting (skip if we just sent them one)
///   3. Loop prevention (see the ignoreUntil field)
model TH_TicketEmailOutbound {
  id             String   @id @default(cuid())
  ticketId       String
  mode           String   // 'NEW_TICKET' | 'STAFF_REPLY'
  toEmail        String
  subject        String
  sentAt         DateTime @default(now())
  /// Drop inbound mail from toEmail for this long after an outbound —
  /// blocks vacation responder loops. Inbox pipeline checks this.
  ignoreUntil    DateTime?

  @@index([ticketId, sentAt])
  @@index([toEmail, sentAt])
  @@map("th_ticket_email_outbound")
  @@schema("tickethub")
}

/// Senders (email OR domain) that should never make it to the inbox.
/// Checked at webhook ingest time — matches bypass the pipeline.
model TH_BlockedSender {
  id          String   @id @default(cuid())
  /// Full address OR bare domain (e.g. "joe@acme.com" or "acme.com")
  value       String   @unique
  /// "EMAIL" | "DOMAIN"
  kind        String
  reason      String?
  createdById String?
  createdAt   DateTime @default(now())

  @@map("th_blocked_senders")
  @@schema("tickethub")
}

// ─── ATTACHMENTS & SIGNATURES ─────────────────────────────────────────────

model TH_Attachment {
  id           String      @id @default(cuid())
  ticketId     String?
  ticket       TH_Ticket?  @relation(fields: [ticketId], references: [id])
  invoiceId    String?
  invoice      TH_Invoice? @relation(fields: [invoiceId], references: [id])
  uploadedById String
  filename     String
  fileUrl      String
  mimeType     String
  sizeBytes    Int
  clientOpId   String?     @unique
  gpsLat       Float?
  gpsLng       Float?
  createdAt    DateTime    @default(now())

  @@map("th_attachments")
  @@schema("tickethub")
}

model TH_Signature {
  id           String    @id @default(cuid())
  ticketId     String
  ticket       TH_Ticket @relation(fields: [ticketId], references: [id])
  signedByName String
  signatureUrl String
  gpsLat       Float?
  gpsLng       Float?
  clientOpId   String?   @unique
  createdAt    DateTime  @default(now())

  @@map("th_signatures")
  @@schema("tickethub")
}

// ─── OFFLINE SYNC QUEUE ───────────────────────────────────────────────────

model TH_SyncQueue {
  id         String    @id @default(cuid())
  userId     String
  type       String
  entityType String
  entityId   String?
  payload    Json
  status     String    @default("PENDING")
  retryCount Int       @default(0)
  error      String?
  createdAt  DateTime  @default(now())
  syncedAt   DateTime?

  @@map("th_sync_queue")
  @@schema("tickethub")
}

// ─── KNOWLEDGE BASE ───────────────────────────────────────────────────────

model TH_KBArticle {
  id             String   @id @default(cuid())
  title          String
  body           String
  tags           String[]
  isPublic       Boolean  @default(false)
  sourceTicketId String?
  authorId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("th_kb_articles")
  @@schema("tickethub")
}

// ─── TAX RATES ────────────────────────────────────────────────────────────

model TH_TaxRate {
  id        String   @id @default(cuid())
  state     String   @unique // ISO 3166-2 US state code (WV/MD/PA/…)
  rateBps   Int      // basis points — 600 = 6.00%
  label     String?  // optional display name ("West Virginia")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("th_tax_rates")
  @@schema("tickethub")
}

// ─── TICKET TIMER (in-progress work time) ────────────────────────────────

model TH_TicketTimer {
  id        String    @id @default(cuid())
  userId    String    @unique // one active timer per user
  ticketId  String
  startedAt DateTime  @default(now())
  /// When set, the timer is paused. pausedAt→resume adds to pausedMs.
  pausedAt  DateTime?
  pausedMs  Int       @default(0)
  note      String?
  createdAt DateTime  @default(now())

  @@map("th_ticket_timers")
  @@schema("tickethub")
}

// ─── SLA POLICIES ─────────────────────────────────────────────────────────

model TH_SlaPolicy {
  id              String            @id @default(cuid())
  priority        TH_TicketPriority @unique
  responseMinutes Int               // time-to-first-response target
  resolveMinutes  Int               // total time-to-resolve target
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("th_sla_policies")
  @@schema("tickethub")
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────

model TH_Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  isRead    Boolean   @default(false)
  data      Json?
  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@map("th_notifications")
  @@schema("tickethub")
}

// ─── LOCATION TRACKING ──────────────────────────────────────────────────

model TH_LocationPing {
  id        String   @id @default(cuid())
  userId    String
  user      TH_User  @relation("LocationPings", fields: [userId], references: [id])
  latitude  Float
  longitude Float
  accuracy  Float?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("th_location_pings")
  @@schema("tickethub")
}

model TH_StoppingPoint {
  id             String    @id @default(cuid())
  userId         String
  user           TH_User   @relation("StoppingPoints", fields: [userId], references: [id])
  latitude       Float
  longitude      Float
  arrivedAt      DateTime
  departedAt     DateTime?
  durationMinutes Int?
  /// Nearest client site (if within radius)
  nearestSiteId  String?
  nearestSite    TH_Site?  @relation(fields: [nearestSiteId], references: [id])
  distanceMeters Float?
  /// Was a ticket created at this site during this stop?
  ticketCreated  Boolean   @default(false)
  ticketId       String?

  @@index([userId, arrivedAt])
  @@map("th_stopping_points")
  @@schema("tickethub")
}

// ─── REMINDERS ──────────────────────────────────────────────────────────

enum TH_ReminderStatus {
  ACTIVE
  SNOOZED
  ACKNOWLEDGED
  CANCELLED
  @@schema("tickethub")
}

enum TH_ReminderSource {
  MANUAL
  SYNCRO_ESTIMATE
  TICKETHUB_ESTIMATE
  @@schema("tickethub")
}

enum TH_ReminderRecurrence {
  ONCE
  DAILY
  EVERY_3_DAYS
  WEEKLY
  @@schema("tickethub")
}

model TH_Reminder {
  id            String                @id @default(cuid())
  contactId     String
  contact       TH_Contact            @relation(fields: [contactId], references: [id])
  createdById   String?
  createdBy     TH_User?              @relation("ReminderCreator", fields: [createdById], references: [id])

  source        TH_ReminderSource
  /// External ID to deduplicate (e.g., Syncro estimate ID)
  externalRef   String?

  title         String
  body          String?
  /// URL the contact can follow (e.g., Syncro estimate link)
  actionUrl     String?

  status        TH_ReminderStatus     @default(ACTIVE)
  recurrence    TH_ReminderRecurrence @default(EVERY_3_DAYS)
  dueDate       DateTime?

  /// When the next notification should fire
  nextNotifyAt  DateTime
  lastNotifiedAt DateTime?
  notifyCount   Int                   @default(0)

  snoozedUntil  DateTime?
  acknowledgedAt DateTime?
  cancelledAt    DateTime?

  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  deliveries    TH_ReminderDelivery[]

  @@unique([source, externalRef])
  @@index([status, nextNotifyAt])
  @@map("th_reminders")
  @@schema("tickethub")
}

model TH_ReminderDelivery {
  id          String      @id @default(cuid())
  reminderId  String
  reminder    TH_Reminder @relation(fields: [reminderId], references: [id])
  channel     String      // EMAIL | NTFY
  toAddress   String
  sentAt      DateTime    @default(now())
  error       String?

  @@index([reminderId, sentAt])
  @@map("th_reminder_deliveries")
  @@schema("tickethub")
}

model TH_ContactPortalToken {
  id          String    @id @default(cuid())
  contactId   String
  contact     TH_Contact @relation(fields: [contactId], references: [id])
  token       String    @unique @default(cuid())
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@map("th_contact_portal_tokens")
  @@schema("tickethub")
}

// ─── SETTINGS (DB-BACKED CONFIG) ─────────────────────────────────────────

model TH_Setting {
  key       String   @id
  value     String   // AES-256-GCM encrypted
  updatedAt DateTime @updatedAt

  @@map("th_settings")
  @@schema("tickethub")
}

// ─── QBO INTEGRATION ─────────────────────────────────────────────────────

model TH_QboToken {
  id            String   @id @default("singleton")
  realmId       String
  accessToken   String
  refreshToken  String
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("th_qbo_tokens")
  @@schema("tickethub")
}

// ─── AMAZON PRICE CACHE ──────────────────────────────────────────────────

model TH_AmazonPriceCache {
  asin        String   @id
  title       String
  price       Int      // cents
  imageUrl    String?
  productUrl  String
  fetchedAt   DateTime @default(now())

  @@map("th_amazon_price_cache")
  @@schema("tickethub")
}
